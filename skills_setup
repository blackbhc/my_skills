# ---- 函数：更新单 skill 仓库 ----
update_single() {
    local name="$1" url="$2" dst="${TARGET}/${name}"

    if [[ -d "${dst}/.git" ]]; then
        echo "[UPD] ${name}"
        git -C "${dst}" pull --ff-only 2>/dev/null || echo "  └─ 更新失败（网络问题），使用已有版本"
    else
        echo "[CLN] ${name}"
        rm -rf "${dst}"
        git clone "${url}" "${dst}" --depth=1 2>/dev/null || {
            echo "  └─ 克隆失败（网络问题），跳过 ${name}"
            return
        }
    fi
}

# ---- 函数：从多 skill 仓库复制指定 skill ----
update_multi() {
    local name="$1" url="$2" subpath="$3"
    local dst="${TARGET}/${name}"

    # 生成缓存目录名（基于仓库 URL）
    local cache_name
    cache_name=$(echo "${url}" | sed 's|https://github.com/||; s|\.git$||; s|/|_|g')
    local cache_dir="${CACHE}/${cache_name}"

    # 克隆/更新缓存仓库
    if [[ -d "${cache_dir}/.git" ]]; then
        echo "[SYNC] ${cache_name}"
        git -C "${cache_dir}" pull --ff-only --depth=1 2>/dev/null || echo "  └─ 更新失败（网络问题），使用已有缓存"
    else
        echo "[CLONE] ${cache_name}"
        rm -rf "${cache_dir}"
        git clone "${url}" "${cache_dir}" --depth=1 2>/dev/null || {
            echo "  └─ 克隆失败（网络问题），跳过 ${name}"
            return
        }
    fi

    # 从缓存复制指定 skill
    local src="${cache_dir}/${subpath}"
    if [[ ! -d "${src}" ]]; then
        echo "[SKIP] ${name} — 子路径不存在: ${subpath}"
        return
    fi

    echo "[COPY] ${name}"
    rm -rf "${dst}"
    cp -r "${src}" "${dst}"
}

# ---- 主流程 ----
echo "==> 部署目标: ${TARGET}（本地 + 外部）"
mkdir -p "${TARGET}" "${CACHE}"

typeset -i total=0 success=0

for entry in "${SKILLS[@]}"; do
    IFS='|' read -r type name url subpath <<<"${entry}" || true

    case "${type}" in
    single)
        total+=1
        if update_single "${name}" "${url}"; then
            success+=1
        fi
        ;;
    multi)
        total+=1
        if update_multi "${name}" "${url}" "${subpath}"; then
            success+=1
        fi
        ;;
    *)
        echo "[WARN] 未知类型: ${type}"
        ;;
    esac
done

echo "==> 完成: ${success}/${total} 个 skill 部署成功"

# ---- 本地 skill 部署（从仓库根目录复制到 ~/.agents/skills/） ----
MY_SKILLS=(
    skill_builder
    tokens-auto-specialization
)

for skill in "${MY_SKILLS[@]}"; do
    SRC="$(cd "$(dirname "$0")" && pwd)/${skill}"
    DST="${TARGET}/${skill}"

    if [[ ! -d "${SRC}" ]]; then
        echo "[SKIP] ${skill} — 源目录不存在: ${SRC}"
        continue
    fi

    echo "[OK] ${skill}"
    rm -rf "${DST}"
    cp -r "${SRC}" "${DST}"
done

echo "==> 完成，已部署 ${#MY_SKILLS[@]} 个本地 skill + ${success}/${total} 个外部 skill"
